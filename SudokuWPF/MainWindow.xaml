<Window x:Class="SudokuWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sudoku" Height="720" Width="900"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#B0B8C1"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="GameButton" TargetType="Button">
            <Setter Property="Background"      Value="#A03030"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Width"           Value="120"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Margin"          Value="0,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="DiffButton" TargetType="Button">
            <Setter Property="Background"      Value="#A03030"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Margin"          Value="3,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <TextBlock Text="SUDOKU" FontSize="26" FontWeight="Bold"
                   Foreground="#7A1A1A" HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,6">
            <TextBlock Text="Dificuldade:" Foreground="#444"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="BtnCafe"   Content="☕ Café com Leite (9x9)"
                    Click="BtnCafe_Click"   Style="{StaticResource DiffButton}"/>
            <Button x:Name="BtnNormal" Content="😐 Normal (16x16)"
                    Click="BtnNormal_Click" Style="{StaticResource DiffButton}"/>
            <Button x:Name="BtnDeploy" Content="🚨 Extremo (25x25)"
                    Click="BtnDeploy_Click" Style="{StaticResource DiffButton}"/>
        </StackPanel>

        <TextBlock x:Name="LoadingLabel"
                   Text=""
                   FontSize="12"
                   Foreground="#7A1A1A"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

        <TextBlock x:Name="TimerLabel"
                   Text="00:00"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#7A1A1A"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          MaxWidth="700" MaxHeight="520">
                <Grid x:Name="SudokuGrid"/>
            </ScrollViewer>

            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <Button Content="Nova Partida" Click="BtnNovo_Click"
                        Style="{StaticResource GameButton}"/>
                <Button Content="Limpar"       Click="BtnLimpar_Click"
                        Style="{StaticResource GameButton}"/>
                <Button Content="Verificar"    Click="BtnVerificar_Click"
                        Style="{StaticResource GameButton}"/>
                <Button Content="Resolver"     Click="BtnResolver_Click"
                        Style="{StaticResource GameButton}"/>
            </StackPanel>
        </StackPanel>

        <WrapPanel x:Name="NumPad"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

        <TextBlock x:Name="MessageLabel"
                   FontSize="13"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"/>

    </StackPanel>
</Window>